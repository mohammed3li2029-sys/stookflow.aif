rules_version = '2';

/*
  StockFlow — Firestore Security Rules
  =====================================
  Deploy with the Firebase CLI:
    firebase deploy --only firestore:rules
  or paste this into: Firebase Console → Firestore Database → Rules.

  Default policy: any signed-in user (via Firebase Authentication) can
  read and write StockFlow's data collections. This matches the
  prototype's current permission model (all logged-in staff share full
  access). If you need per-role restrictions (e.g. only "admin" or
  "manager" can delete), store a `role` field on each user's Firestore
  profile doc under /users/{uid} and check it here — see the commented
  example at the bottom.
*/

service cloud.firestore {
  match /databases/{database}/documents {

    match /inventory/{docId} {
      allow read, write: if request.auth != null;
    }

    match /warehouses/{docId} {
      allow read, write: if request.auth != null;
    }

    // Add matching blocks here as you migrate more modules
    // (purchasing, sales, projects, movements, users, notifications)
    // to Firestore, following the same pattern.

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // ---- Example: role-based restriction (disabled by default) ----
    // match /inventory/{docId} {
    //   allow read: if request.auth != null;
    //   allow write: if request.auth != null &&
    //     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager'];
    // }
  }
}
